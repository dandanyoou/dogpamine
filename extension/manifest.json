{
  "manifest_version": 3,
  "name": "Dogpamine",
  "version": "0.2.0",
  "description": "포만감 알고리즘 기반 자기제어 익스텐션. 켜고 끄는 건 본인 결정.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dogpamine"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/shorts/*",
        "https://www.instagram.com/reels/*"
      ],
      "js": ["lib/session.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.instagram.com/*"
  ]
}
