{
  "manifest_version": 3,
  "name": "Dogpamine",
  "version": "0.3.0",
  "description": "포만감 알고리즘 기반 자기제어 익스텐션. 켜고 끄는 건 본인 결정.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dogpamine",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/shorts/*",
        "https://www.instagram.com/*"
      ],
      "js": ["lib/session.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.instagram.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["curated.json"],
      "matches": [
        "https://www.youtube.com/*",
        "https://www.instagram.com/*"
      ]
    }
  ]
}
